{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".claude/rules/*.md"],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "git *": "deny",
      "git status *": "allow",
      "git log *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "rm *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.secrets": "deny",
      "*.secrets.*": "deny"
    },
    "edit": "deny"
  }
}
