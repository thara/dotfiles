{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".claude/rules/*.md"],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "git *": "deny",
      "git status *": "allow",
      "git log *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "rm *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "nc *": "deny",
      "curl * | bash": "deny",
      "wget * | bash": "deny"
    },
    "read": {
      "*": "allow",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.secrets": "deny",
      "*.secrets.*": "deny"
    },
    "edit": "deny"
  }
}
